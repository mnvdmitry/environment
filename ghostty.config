# Ghostty конфиг
# Устанавливается в:
#   ~/.config/ghostty/config
#   или ~/Library/Application Support/com.mitchellh.ghostty/config

theme = dark:GitHub Dark Dimmed,light:GitHub Light Default

# Явно говорим Ghostty запускать bash как login shell, чтобы применялся .bash_profile.
# Это гарантирует загрузку brew env и токенов.
command = /bin/bash --login

# Shell integration для bash (inject автоматически; но если захочется явно —
# раскомментировать:)
# shell-integration = bash
